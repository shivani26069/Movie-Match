# Backend environment variables
# Copy this file to `.env` in the project root or in moviematching/backend folder
# and set appropriate values.

# SQLAlchemy database URL
# Examples:
# Postgres: postgresql://postgres:password@localhost:5432/moviematch
# SQLite (for local/dev): sqlite:///./moviematch.db
DATABASE_URL=postgresql://postgres:password@localhost:5432/moviematch

# TMDB API key for seeding via scripts/seed_movies.py
TMDB_API_KEY=90e8e6dba6b4c628c26b190be4dc605d

# Frontend (Vite) config: create scrath frontend/frontend/.env and set
# VITE_API_URL=http://127.0.0.1:8000
